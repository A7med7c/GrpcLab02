{
  "openapi": "3.1.1",
  "info": {
    "title": "NexusVault.RestApi | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7253"
    },
    {
      "url": "http://localhost:5055"
    }
  ],
  "paths": {
    "/api/Devices": {
      "post": {
        "tags": [
          "Devices"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EnrollDeviceRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EnrollDeviceRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EnrollDeviceRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Devices/stream-metrics": {
      "post": {
        "tags": [
          "Devices"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DeviceMetricsDto"
                }
              }
            },
            "text/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DeviceMetricsDto"
                }
              }
            },
            "application/*+json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DeviceMetricsDto"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Records": {
      "get": {
        "tags": [
          "Records"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Records/{id}": {
      "get": {
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Records/monitor/{id}": {
      "get": {
        "tags": [
          "Records"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Records/bulk-update-state": {
      "put": {
        "tags": [
          "Records"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkUpdateProcessingStateDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkUpdateProcessingStateDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/BulkUpdateProcessingStateDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Security/authenticate": {
      "post": {
        "tags": [
          "Security"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CredentialPayload"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CredentialPayload"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CredentialPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BulkUpdateProcessingStateDto": {
        "required": [
          "recordIds",
          "newState"
        ],
        "type": "object",
        "properties": {
          "recordIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "newState": {
            "$ref": "#/components/schemas/ProcessingState"
          }
        }
      },
      "CredentialPayload": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "DeviceCategory": {
        "type": "integer"
      },
      "DeviceMetricsDto": {
        "type": "object",
        "properties": {
          "deviceId": {
            "type": "string"
          },
          "latitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "longitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "velocityKmh": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "float"
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EnrollDeviceRequest": {
        "type": "object",
        "properties": {
          "serialCode": {
            "type": [
              "null",
              "string"
            ]
          },
          "category": {
            "$ref": "#/components/schemas/DeviceCategory"
          },
          "maxLoadKg": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "float"
          }
        }
      },
      "ProcessingState": {
        "type": "integer"
      }
    }
  },
  "tags": [
    {
      "name": "Devices"
    },
    {
      "name": "Records"
    },
    {
      "name": "Security"
    }
  ]
}